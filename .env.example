# Firewall upstream — where /v1/chat/completions requests are forwarded.
# Default points at Gemini's OpenAI-compatible endpoint.
LLM_FIREWALL_UPSTREAM_CHAT_COMPLETIONS_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_FIREWALL_UPSTREAM_API_KEY=your-gemini-api-key
LLM_FIREWALL_DEFAULT_MODEL_ID=gemini-2.5-flash
LLM_FIREWALL_ENABLE_OUTPUT_CLASSIFIERS=true
LLM_FIREWALL_REFUSAL_MESSAGE=Sorry, I cannot answer this prompt

# To use the local dummy upstream instead (run `make dummy` in another terminal),
# replace the three LLM_FIREWALL_UPSTREAM_* lines above with:
#   LLM_FIREWALL_UPSTREAM_CHAT_COMPLETIONS_URL=http://localhost:9000/v1/chat/completions
#   LLM_FIREWALL_UPSTREAM_API_KEY=
#   LLM_FIREWALL_DEFAULT_MODEL_ID=dummy-llm

# Settings consumed by the dummy upstream itself (only used when running `make dummy`).
DUMMY_LLM_API_KEY=
DUMMY_LLM_RESPONSE_TEXT="This is a dummy response."
